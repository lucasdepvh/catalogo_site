<div class="card border">
  <div class="card-header">
    <h5 class="card-title mb-0">Meu perfil</h5>
  </div>

  <div class="card-body">
    <% if @admin.errors.any? %>
      <div class="alert alert-danger">
        <h6 class="mb-2">Nao foi possivel atualizar:</h6>
        <ul class="mb-0">
          <% @admin.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @admin, url: admin_profile_path, method: :patch do |f| %>
      <div class="row">
        <div class="col-12 col-md-7 mb-3">
          <%= f.label :email, "Email", class: "mb-1" %>
          <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
        </div>
      </div>

      <hr>

      <h6>Alterar senha</h6>
      <p class="text-muted mb-3">Preencha apenas se quiser trocar a senha.</p>

      <div class="row">
        <div class="col-12 col-md-7 mb-3">
          <%= f.label :current_password, "Senha atual", class: "mb-1" %>
          <%= f.password_field :current_password, class: "form-control", autocomplete: "current-password" %>
        </div>
      </div>

      <div class="row">
        <div class="col-12 col-md-7 mb-3">
          <%= f.label :password, "Nova senha", class: "mb-1" %>
          <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
        </div>
      </div>

      <div class="row">
        <div class="col-12 col-md-7 mb-4">
          <%= f.label :password_confirmation, "Confirmar nova senha", class: "mb-1" %>
          <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
        </div>
      </div>

      <div class="d-flex justify-content-end">
        <%= button_tag(type: "submit", class: "btn btn-success") do %>
          <i class="bi bi-floppy me-1"></i> Salvar perfil
        <% end %>
      </div>
    <% end %>
  </div>
</div>
