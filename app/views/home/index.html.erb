<div class="container mt-5">
  <div class="row">
    <div class="col-12 col-lg-5 col-xxl-3 mb-5 mx-auto">
      <%= search_form_for @q, url: root_path, method: :get do |f| %>
        <label for="search_product" class="form-label">Pesquisar por Produto</label>
      <div class="input-group">
          <%= f.search_field :title_cont, class: 'form-control', placeholder: 'Ex: Moletom', value: params.dig(:q, :title_cont) %>
        <button type="submit" class="btn btn-primary" data-mdb-ripple-init>
          <i class="bi bi-search"></i>
        </button>
      </div>
      <div class="d-flex mt-2">
        <div class="w-100">
          <div id="price-slider"></div>
          <%= f.hidden_field :price_gteq, id: 'minPriceField' %>
          <%= f.hidden_field :price_lteq, id: 'maxPriceField' %>
        </div>
      </div>
      <div class="mt-3 col-md-12">
        <label for="search_product" class="form-label">Ordenar preço por: </label>
        <%= f.select :s, [['Mais Baixo', 'price asc'], ['Mais Alto', 'price desc']], { include_blank: 'Selecione a ordem' }, { class: 'form-select', onchange: 'this.form.submit()' } %>
      </div>
      <% end %>
      <div class="sidebar mt-5">
        <section>
          <h5 class="mb-3">CATEGORIAS</h5>
          <% Category.all.each do |category| %>
          <%= link_to "#{category.description} (#{category.products.size})", root_path(q: { category_id_eq: category.id }), class: 'link-secondary d-block' %>
          <% end %>
        </section>
      </div>
    </div>

    <div class="col-12 col-lg-7 col-xxl-9">
      <div class="row mb-3">
        <div class="col-6">
          <span class="d-none d-md-block"><%= "Mostrando #{@products.present? ? "1" : "0"}-#{@products&.size} de #{@pagy&.count} resultados" %></span>
        </div>
  
      </div>
      <div class="row">
        <% @products.each do |product| %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-6 col-xl-4 mb-3">
          <div class="card card-image-product">
            <%= link_to product_path(product) do %>
            <%= image_tag set_image_product_or_ilustration_src(product), alt: "Minha Imagem", class: 'card-img-top' %>
            <% end %>
            <div class="card-body pt-3 p-4">
              <h6 class="fs-4"><%= product.title %></h6>
              <div class="d-flex align-items-center justify-content-between">
                <h6 class="fs-4 mb-0">
                  <%= number_to_currency(product.price, unit: "R$ ", separator: ",", delimiter: ".", precision: 2) %>
                </h6>
              </div>
            </div>
          </div>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
